# ============================================================
# Tanren Agent — Environment Configuration
# ============================================================
# Copy to .env and fill in values:  cp .env.example .env
#
# Only configure what you need. Tanren works with zero config
# (uses Claude CLI with your local installation).
# ============================================================

# ── LLM Provider (choose ONE) ──────────────────────────────

# Option 1: Anthropic API (recommended for production)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OpenAI-compatible (Ollama, vLLM, omlx, LiteLLM)
# LLM_PROVIDER=omlx
# LOCAL_LLM_URL=http://localhost:8000
# LOCAL_LLM_MODEL=Qwen3.5-4B-MLX-4bit
# LOCAL_LLM_KEY=local

# Option 3: Claude CLI (default — no config needed)
# Uses your local `claude` installation. No API key required.

# ── Server ──────────────────────────────────────────────────

# HTTP server port (tanren serve)
# PORT=3002

# ── Agent Identity ──────────────────────────────────────────

# Agent name (used in logs and API responses)
# AGENT_NAME=my-agent

# ── Optional Services ──────────────────────────────────────

# Agora discussion service URL (multi-agent collaboration)
# AGORA_URL=http://127.0.0.1:3003
