  },
  "files": [
    "dist",
    "gates"
  ],
  "keywords": [
    "ai",
    "agent",
    "framework",
    "learning",
    "autonomous"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
